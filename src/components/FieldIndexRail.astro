---
import { fieldIndex } from '../data/site';
import type { Locale } from '../i18n/config';
import { localizedPath } from '../i18n/routes';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const label = locale === 'en' ? 'Career fields' : '职业领域';
const workPath = localizedPath(locale, 'work');
---

<nav class="field-index" aria-label={label}>
  <ol class="field-index__list shell">
    {fieldIndex.map((field) => (
      <li class="field-index__item">
        <a class="field-index__link" href={`${workPath}#${field.key}`}>
          {field[locale]}
        </a>
      </li>
    ))}
  </ol>
</nav>
