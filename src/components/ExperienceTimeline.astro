---
import { experience, type ExperienceEntry } from '../data/experience';
import type { Locale } from '../i18n/config';

interface Props {
  locale: Locale;
  mode?: 'compact' | 'full';
  entries?: ExperienceEntry[];
}

const { locale, mode = 'full', entries = experience } = Astro.props;
const orderedEntries = [...entries].reverse();
const visibleEntries = mode === 'compact' ? orderedEntries.slice(0, 3) : orderedEntries;
---

<div class:list={['experience-timeline', { 'experience-timeline--compact': mode === 'compact' }]}>
  {visibleEntries.map((entry) => (
    <article class="experience-timeline__item">
      <p class="experience-timeline__period">{entry.period[locale]}</p>
      <div>
        <h3 class="experience-timeline__heading">
          {entry.company[locale]} — {entry.role[locale]}
        </h3>
        <p class="experience-timeline__summary">{entry.summary[locale]}</p>
        {mode === 'full' && (
          <ul class="experience-timeline__highlights">
            {entry.highlights[locale].map((highlight) => <li>{highlight}</li>)}
          </ul>
        )}
      </div>
    </article>
  ))}
</div>
