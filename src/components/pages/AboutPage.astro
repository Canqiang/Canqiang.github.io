---
import { patents, publications } from '../../data/achievements';
import { education, interests } from '../../data/profile';
import type { Locale } from '../../i18n/config';
import ContactLinks from '../ContactLinks.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = locale === 'en'
  ? {
      label: 'Profile and record',
      title: 'Research curiosity, engineering discipline, product judgment.',
      bio: 'My path began in bioinformatics research, moved through medical AI and LLM product engineering, and now centers on open-source agent systems and the platform work needed to ship them reliably.',
      education: 'Education',
      research: 'Research record',
      researchLede: 'Peer-reviewed publications and public patent records from biomedical research and engineering work.',
      interests: 'Interests',
      contact: 'Contact',
      contactLede: 'Public channels for engineering roles, open-source collaboration, and research conversations.',
    }
  : {
      label: '个人介绍与成果',
      title: '以研究好奇心、工程纪律与产品判断连接工作。',
      bio: '我的职业路径始于生物信息研究，随后进入医疗 AI 与大模型产品研发，如今聚焦开源智能体系统，以及支撑其可靠落地的平台工程。',
      education: '教育经历',
      research: '科研成果',
      researchLede: '来自生物医学研究与工程工作的同行评议论文和公开专利记录。',
      interests: '兴趣爱好',
      contact: '联系方式',
      contactLede: '欢迎通过公开渠道交流工程岗位、开源协作与研究话题。',
    };
---

<header class="page-intro shell about-intro">
  <p class="page-intro__label">{copy.label}</p>
  <h1 class="page-intro__title display">{copy.title}</h1>
  <p class="page-intro__summary">{copy.bio}</p>
</header>

<div class="about-profile shell">
  <section class="about-profile__education" aria-labelledby="education-title">
    <p class="about-profile__index" aria-hidden="true">EDU</p>
    <div>
      <h2 id="education-title">{copy.education}</h2>
      <p class="about-profile__degree">{education.degree[locale]}</p>
      <p>{education.institution[locale]}</p>
      <p class="about-profile__meta">{education.period}</p>
    </div>
  </section>

  <section id="record" class="about-profile__record" aria-labelledby="research-title">
    <header class="about-profile__section-header">
      <div>
        <p class="portfolio-section__eyebrow">{publications.label[locale]} + {patents.label[locale]}</p>
        <h2 id="research-title">{copy.research}</h2>
      </div>
      <p>{copy.researchLede}</p>
    </header>
    <div class="about-evidence-grid">
      {[publications, patents].map((group) => (
        <article class="about-evidence">
          <h3>{group.label[locale]}</h3>
          <ol>
            {group.items.map((item) => (
              <li>
                {item.href ? <a href={item.href}>{item.title[locale]}</a> : <span>{item.title[locale]}</span>}
                <small>{item.detail[locale]}</small>
              </li>
            ))}
          </ol>
        </article>
      ))}
    </div>
  </section>

  <div class="about-profile__personal">
    <section aria-labelledby="interests-title">
      <p class="about-profile__index" aria-hidden="true">OFF</p>
      <h2 id="interests-title">{copy.interests}</h2>
      <ul class="about-interest-list">
        {interests.map((interest) => <li>{interest[locale]}</li>)}
      </ul>
    </section>
    <section aria-labelledby="contact-title">
      <p class="about-profile__index" aria-hidden="true">LINK</p>
      <h2 id="contact-title">{copy.contact}</h2>
      <p>{copy.contactLede}</p>
      <ContactLinks {locale} />
    </section>
  </div>
</div>
