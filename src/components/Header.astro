---
import type { Locale } from '../i18n/config';
import { localeMeta } from '../i18n/config';
import { alternateLocalePath, localizedPath, type RouteKey } from '../i18n/routes';

interface Props {
  locale: Locale;
  pathname: string;
  hasLocalePair?: boolean;
}

const { locale, pathname, hasLocalePair = true } = Astro.props;
const copy = locale === 'en'
  ? { work: 'Work', projects: 'Projects', about: 'About', menu: 'Menu', switchLabel: '切换至中文' }
  : { work: '经历', projects: '项目', about: '关于', menu: '菜单', switchLabel: 'Switch to English' };
const navigation: Array<{ key: Exclude<RouteKey, 'home' | 'project' | 'resume'>; label: string }> = [
  { key: 'work', label: copy.work },
  { key: 'projects', label: copy.projects },
  { key: 'about', label: copy.about },
];
const normalizedPath = pathname.endsWith('/') ? pathname : `${pathname}/`;
const isCurrent = (key: (typeof navigation)[number]['key']) => {
  const target = localizedPath(locale, key);
  return key === 'projects'
    ? normalizedPath === target || normalizedPath.startsWith(target)
    : normalizedPath === target;
};
const destinationLocale: Locale = locale === 'en' ? 'zh' : 'en';
---

<header class="site-header">
  <div class="site-header__inner shell">
    <a class="site-header__identity" href={localizedPath(locale, 'home')} aria-label={`${locale === 'en' ? 'Xander Xu' : '许灿强'} — ${locale === 'en' ? 'Home' : '首页'}`}>
      Xander <span class="site-header__identity-mark">/</span> Canqiang
    </a>

    <button
      class="site-header__menu-button no-print"
      type="button"
      aria-expanded="false"
      aria-controls="site-navigation"
      data-menu-toggle
    >
      {copy.menu}
    </button>
    <noscript><style>.site-header__menu-button { display: none !important; }</style></noscript>

    <nav id="site-navigation" class="site-header__nav" aria-label={locale === 'en' ? 'Primary navigation' : '主导航'} data-site-navigation>
      <ul class="site-header__nav-list">
        {navigation.map(({ key, label }) => (
          <li>
            <a class="site-header__nav-link" href={localizedPath(locale, key)} aria-current={isCurrent(key) ? 'page' : undefined}>
              {label}
            </a>
          </li>
        ))}
        {hasLocalePair && (
          <li>
            <a
              class="site-header__nav-link site-header__language-link"
              href={alternateLocalePath(pathname)}
              hreflang={localeMeta[destinationLocale].hreflang}
              lang={localeMeta[destinationLocale].lang}
              aria-label={copy.switchLabel}
            >
              {localeMeta[locale].switchLabel}
            </a>
          </li>
        )}
      </ul>
    </nav>
  </div>
</header>

<script>
  const menuButton = document.querySelector('[data-menu-toggle]');
  const navigation = document.querySelector('[data-site-navigation]');

  if (menuButton instanceof HTMLButtonElement && navigation instanceof HTMLElement) {
    const mobile = window.matchMedia('(max-width: 47.99rem)');
    const syncMenu = () => {
      const expanded = !mobile.matches;
      menuButton.setAttribute('aria-expanded', String(expanded));
      navigation.hidden = !expanded;
    };
    const toggleMenu = () => {
      const expanded = menuButton.getAttribute('aria-expanded') === 'true';
      menuButton.setAttribute('aria-expanded', String(!expanded));
      navigation.hidden = expanded;
    };

    menuButton.addEventListener('click', toggleMenu);
    mobile.addEventListener('change', syncMenu);
    syncMenu();
  }
</script>
